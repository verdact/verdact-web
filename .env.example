# Verdact Web — environment template
#
# Copy to `.env.local` for local development and fill in real values.
# Production/preview values are configured in the Vercel project, never committed.
# Vars prefixed NEXT_PUBLIC_ are exposed to the browser — never put secrets there.
#
# Each var notes whether it is currently wired in the app source or only
# provisioned ahead of the feature that will consume it.

# ---------------------------------------------------------------------------
# Core app
# ---------------------------------------------------------------------------
# Public base URL of the app, used for OAuth redirect/return URLs. No trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Supabase (database, auth, RLS) — required
# ---------------------------------------------------------------------------
# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Anon/publishable key — safe for the browser, RLS enforces access.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service-role key — server-only, bypasses RLS. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------------------------------------------------------
# Stripe (Connect onboarding + dispute webhook) — required for Stripe flows
# ---------------------------------------------------------------------------
# Secret API key (sk_test_... in dev, sk_live_... in prod).
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# Connect client id (ca_...) for the Standard OAuth connect flow.
STRIPE_CONNECT_CLIENT_ID=ca_your-connect-client-id
# Webhook signing secret (whsec_...) used to verify inbound Stripe events.
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ---------------------------------------------------------------------------
# Slack (notification integration) — required for Slack connect flow
# ---------------------------------------------------------------------------
# Slack app OAuth client id.
SLACK_CLIENT_ID=your-slack-client-id
# Slack app OAuth client secret.
SLACK_CLIENT_SECRET=your-slack-client-secret

# ---------------------------------------------------------------------------
# Google OAuth (Gmail reviewer / import path) — required for the Gmail path
# ---------------------------------------------------------------------------
# Secret used to encrypt the reviewer/Gmail HTTP-only cookie (random 32+ char string).
NEXTAUTH_SECRET=generate-a-long-random-secret
# Google OAuth client id.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Google OAuth client secret.
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ---------------------------------------------------------------------------
# Transactional email (Resend) — provisioned; email sending not yet wired
# ---------------------------------------------------------------------------
# Resend API key (re_...).
RESEND_API_KEY=re_your-resend-api-key
# From address for transactional email, e.g. Verdact <hello@verdact.io>.
EMAIL_FROM=Verdact <hello@verdact.io>

# ---------------------------------------------------------------------------
# Anthropic (AI evidence-narrative) — wired; kill switch OFF by default
# ---------------------------------------------------------------------------
# Anthropic API key (sk-ant-...).
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# Master switch for the "Draft with AI" button in the evidence workbench. Unset
# or anything other than "true" = OFF (button hidden, no API calls). Flip to
# "true" only when you want AI drafting live.
VERDACT_AI_NARRATIVE_ENABLED=false
# Optional model override (defaults to claude-3-5-sonnet-20241022). Set to a
# model your ANTHROPIC_API_KEY can access.
# VERDACT_AI_NARRATIVE_MODEL=claude-3-5-sonnet-20241022

# ---------------------------------------------------------------------------
# Inngest (background jobs) — read automatically by the Inngest client
# ---------------------------------------------------------------------------
# Event key for sending events to Inngest (required in production).
INNGEST_EVENT_KEY=your-inngest-event-key
# Signing key for verifying Inngest requests (required in production).
INNGEST_SIGNING_KEY=signkey-your-inngest-signing-key

# ---------------------------------------------------------------------------
# Analytics (PostHog) — inert until the key is set
# ---------------------------------------------------------------------------
# PostHog project API key (US Cloud). Events reverse-proxy through /ingest.
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key

# ---------------------------------------------------------------------------
# Audit / abuse controls
# ---------------------------------------------------------------------------
# Salt for hashing client IPs on the public /audit endpoint. REQUIRED in production
# (the app throws without it); a public default is used only in non-production.
AUDIT_IP_SALT=generate-a-long-random-salt

# ---------------------------------------------------------------------------
# Access gates and feature flags
# ---------------------------------------------------------------------------
# Optional code gating the reviewer sign-in path. Leave unset to disable the gate.
REVIEWER_ACCESS_CODE=
# Emergency comma-separated admin email allowlist (DB is the source of truth).
VERDACT_ADMIN_EMAILS=
# Set to "on" to enable best-effort geo capture on signup/audit rows. Off by default.
ADMIN_GEO_CAPTURE=off
# Master beta flag: anything but "false"/"0" unlocks every gated action for everyone.
VERDACT_BETA_ALL_UNLOCKED=true
# Kill switch for auto-submit. Hard-off unless set to exactly "true".
VERDACT_AUTO_SUBMIT_ENABLED=false
# Kill switch for LIVE Stripe dispute filing (manual "submit to Stripe"). Hard-off
# unless set to exactly "true". Default off: the submission flow is built and
# test-mode-exercisable but inert in production. Flip to "true" ONLY after the
# legal gates close (Delaware LLC + F-1/OPT clearance). When on with sk_test it
# files against test-mode disputes; with sk_live it files real evidence.
VERDACT_SUBMISSION_ENABLED=false
# Optional HMAC key to sign the immutable submitted-evidence payload. If unset the
# submission still records a sha256 of the payload (signature columns stay null).
VERDACT_SUBMISSION_SIGNING_KEY=
